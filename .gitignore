# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# ---- Virtual environments ----
.venv/
venv/
env/
.conda/

# ---- Credentials and secrets (never commit) ----
.env
*.env
*.key
*.pem
credentials.json
service_account*.json
.netrc

# ---- Geospatial data and large outputs ----
# Keep heavy or sensitive data out of the repo; ship only a tiny sample_data/ folder.
*.tif
*.tiff
*.zarr/
*.nc
*.h5
*.hdf
*.parquet
*.shp
*.shx
*.dbf
*.prj
*.gpkg
data/
outputs/
store/

# Allow the small curated sample that lets the tool run end to end
!sample_data/
!sample_data/**

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
.vscode/
.idea/
